@{
    ViewBag.Title = "Resistencias";
}

<style>
    body {
        background-color: #1a1a2e;
    }

    .res-container {
        background: linear-gradient(to bottom, #16213e, #0f3460);
        border: 3px solid #e0e0e0;
        border-radius: 10px;
        padding: 30px;
        margin-top: 20px;
        color: white;
        box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }

    .titulo-principal {
        text-align: center;
        margin-bottom: 25px;
    }

        .titulo-principal span {
            background: white;
            color: #0f3460;
            padding: 6px 30px;
            font-size: 26px;
            font-family: Georgia;
            font-style: italic;
            font-weight: bold;
            border-radius: 4px;
        }

    .panel-box {
        border: 2px solid rgba(255,255,255,0.4);
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .panel-titulo {
        font-size: 20px;
        font-style: italic;
        font-family: Georgia;
        margin-bottom: 15px;
        color: white;
    }

    .campo {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .campo label {
            width: 150px;
            font-size: 15px;
        }

        .campo select {
            width: 160px;
            padding: 4px;
            border-radius: 3px;
            color: black;
        }

    .radio-group {
        display: flex;
        gap: 20px;
    }

    .acciones-box {
        text-align: center;
        margin-top: 10px;
        margin-bottom: 20px;
    }

    .btn-custom {
        background: #f2f2f2;
        border: 1px solid #999;
        padding: 8px 25px;
        margin: 0 10px;
        border-radius: 4px;
        color: black;
        font-weight: bold;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-custom:hover {
            background: #ddd;
            color: black;
            text-decoration: none;
        }

    .tabla-resultados {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
        font-size: 14px;
    }

        .tabla-resultados th {
            background: rgba(255,255,255,0.2);
            color: white;
            padding: 8px;
            border: 1px solid rgba(255,255,255,0.3);
            text-align: center;
        }

        .tabla-resultados td {
            padding: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            text-align: center;
            color: white;
        }

    .color-Negro {
        background-color: #111111 !important;
        color: white !important;
    }

    .color-Cafe {
        background-color: #795548 !important;
        color: white !important;
    }

    .color-Rojo {
        background-color: #c62828 !important;
        color: white !important;
    }

    .color-Naranja {
        background-color: #e65100 !important;
        color: white !important;
    }

    .color-Amarillo {
        background-color: #f9a825 !important;
        color: black !important;
    }

    .color-Verde {
        background-color: #2e7d32 !important;
        color: white !important;
    }

    .color-Azul {
        background-color: #1565c0 !important;
        color: white !important;
    }

    .color-Violeta {
        background-color: #6a1b9a !important;
        color: white !important;
    }

    .color-Gris {
        background-color: #616161 !important;
        color: white !important;
    }

    .color-Blanco {
        background-color: #f5f5f5 !important;
        color: black !important;
    }
</style>

<div class="container">
    <div class="res-container">

        <div class="titulo-principal">
            <span>Resistencias</span>
        </div>

        @using (Html.BeginForm())
        {
            <div class="row">

                <div class="col-md-4">
                    <div class="panel-box">
                        <div class="panel-titulo">Primera Banda</div>
                        <div class="campo">
                            <label>Color 1</label>
                            @Html.DropDownList("Color1", (List<SelectListItem>)ViewBag.Colores)
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="panel-box">
                        <div class="panel-titulo">Segunda Banda</div>
                        <div class="campo">
                            <label>Color 2</label>
                            @Html.DropDownList("Color2", (List<SelectListItem>)ViewBag.Colores)
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="panel-box">
                        <div class="panel-titulo">Tercera Banda</div>
                        <div class="campo">
                            <label>Color 3</label>
                            @Html.DropDownList("Color3", (List<SelectListItem>)ViewBag.Colores)
                        </div>
                    </div>
                </div>

            </div>

            <!-- Tolerancia -->
            <div class="panel-box" style="width: 300px; margin: 0 auto 20px;">
                <div class="panel-titulo">Tolerancia</div>
                <div class="radio-group">
                    <label>
                        <input type="radio" name="Tolerancia" value="Oro" checked /> Oro (5%)
                    </label>
                    <label>
                        <input type="radio" name="Tolerancia" value="Plata" /> Plata (10%)
                    </label>
                </div>
            </div>

            <!-- Botones -->
            <div class="acciones-box">
                <button type="submit" class="btn-custom">Registrar</button>
                @Html.ActionLink("Salir", "Index", "Home", null, new { @class = "btn-custom" })
            </div>
        }

        <!-- Tabla de resultados -->
        @if (ViewBag.Resultados != null)
        {
            var lista = (List<IDGS904ASP.Models.ResistenciaResultado>)ViewBag.Resultados;

            if (lista.Count > 0)
            {
                <div class="panel-box">
                    <div class="panel-titulo">Resultados</div>
                    <table class="tabla-resultados">
                        <thead>
                            <tr>
                                <th>Color 1</th>
                                <th>Color 2</th>
                                <th>Color 3</th>
                                <th>Tolerancia</th>
                                <th>Valor (Ω)</th>
                                <th>Valor Máximo</th>
                                <th>Valor Mínimo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in lista)
                            {
                                <tr>
                                    <td class="color-@item.Color1">@item.Color1</td>
                                    <td class="color-@item.Color2">@item.Color2</td>
                                    <td class="color-@item.Color3">@item.Color3</td>
                                    <td>@item.Tolerancia</td>
                                    <td>@item.Valor</td>
                                    <td>@item.ValorMax</td>
                                    <td>@item.ValorMin</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }

    </div>
</div>
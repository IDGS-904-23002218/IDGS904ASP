@model IDGS904ASP.Models.Busqueda

@{
    ViewBag.Title = "Diccionario - Buscar";
}

<style>
    body {
        background-color: #1a1a2e;
    }

    .dic-container {
        background: linear-gradient(to bottom, #16213e, #0f3460);
        border: 3px solid #e0e0e0;
        border-radius: 10px;
        padding: 30px;
        margin-top: 20px;
        color: white;
        box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }

    .titulo-principal {
        text-align: center;
        margin-bottom: 25px;
    }

        .titulo-principal span {
            background: white;
            color: #0f3460;
            padding: 6px 30px;
            font-size: 26px;
            font-family: Georgia;
            font-style: italic;
            font-weight: bold;
            border-radius: 4px;
        }

    .panel-box {
        border: 2px solid rgba(255,255,255,0.4);
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        width: 400px;
        margin-left: auto;
        margin-right: auto;
    }

    .panel-titulo {
        font-size: 20px;
        font-style: italic;
        font-family: Georgia;
        margin-bottom: 15px;
        color: white;
    }

    .campo {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .campo label {
            width: 130px;
            font-size: 15px;
            color: white;
        }

        .campo input[type="text"] {
            width: 200px;
            padding: 5px;
            border-radius: 3px;
            border: none;
            color: black;
        }

    .radio-group {
        display: flex;
        gap: 20px;
        margin-bottom: 15px;
        color: white;
    }

    .acciones-box {
        text-align: center;
        margin-top: 15px;
    }

    .btn-custom {
        background: #f2f2f2;
        border: 1px solid #999;
        padding: 8px 25px;
        margin: 0 10px;
        border-radius: 4px;
        color: black;
        font-weight: bold;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-custom:hover {
            background: #ddd;
            color: black;
            text-decoration: none;
        }

    .error {
        color: yellow;
        text-align: center;
        margin-top: 15px;
        font-weight: bold;
    }

    .tabla-resultados {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

        .tabla-resultados th {
            border: 1px solid white;
            padding: 8px;
            color: white;
            text-align: center;
        }

        .tabla-resultados td {
            border: 1px solid white;
            padding: 8px;
            color: white;
            text-align: center;
        }
</style>

<div class="container">
    <div class="dic-container">

        <div class="titulo-principal">
            <span>Diccionario — Buscar</span>
        </div>

        @using (Html.BeginForm("Buscar", "Diccionario", FormMethod.Post))
        {
            <div class="panel-box">
                <div class="panel-titulo">Buscar Palabra</div>

                <div class="radio-group">
                    <label>
                        <input type="radio" name="Idioma" value="Espanol"
                               @(ViewBag.Idioma == "Ingles" ? "" : "checked") /> Español
                    </label>
                    <label>
                        <input type="radio" name="Idioma" value="Ingles"
                               @(ViewBag.Idioma == "Ingles" ? "checked" : "") /> Inglés
                    </label>
                </div>

                <div class="campo">
                    @Html.LabelFor(m => m.Termino)
                    @Html.TextBoxFor(m => m.Termino)
                </div>

                @if (ViewBag.Resultado != null)
                {
                    <table class="tabla-resultados">
                        <thead>
                            <tr>
                                <th>Inglés</th>
                                <th>Español</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>@(ViewBag.Idioma == "Ingles" ? ViewBag.Termino : ViewBag.Resultado)</td>
                                <td>@(ViewBag.Idioma == "Espanol" ? ViewBag.Termino : ViewBag.Resultado)</td>
                            </tr>
                        </tbody>
                    </table>
                }
            </div>

            <div class="acciones-box">
                <input type="submit" value="Buscar" class="btn-custom" />
                @Html.ActionLink("Capturar", "Capturar", "Diccionario", null, new { @class = "btn-custom" })
                @Html.ActionLink("Salir", "Index", "Home", null, new { @class = "btn-custom" })
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

    </div>
</div>
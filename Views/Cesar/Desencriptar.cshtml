@model IDGS904ASP.Models.Desencriptar

@{
    ViewBag.Title = "Desencriptar";
}

<style>
    body {
        background-color: #1a1a2e;
    }

    .des-container {
        background: white;
        border: 3px solid black;
        border-radius: 10px;
        padding: 30px;
        margin-top: 20px;
        width: 400px;
    }

    .campo {
        margin-bottom: 15px;
    }

        .campo label {
            display: block;
            font-weight: bold;
            margin-bottom: 5px;
            color: black;
        }

        .campo input[type="number"] {
            width: 100%;
            padding: 5px;
            border: 1px solid black;
            border-radius: 3px;
            color: black;
        }

        .campo select {
            width: 100%;
            padding: 5px;
            border: 1px solid black;
            border-radius: 3px;
            color: black;
        }

    .btn-custom {
        background: #f2f2f2;
        border: 2px solid black;
        padding: 8px 25px;
        border-radius: 20px;
        font-weight: bold;
        cursor: pointer;
        margin-top: 10px;
    }

        .btn-custom:hover {
            background: #ddd;
        }

    .resultado {
        margin-top: 15px;
        color: black;
    }

    .correcto {
        color: #00aa00;
        font-weight: bold;
        font-size: 18px;
    }

    .incorrecto {
        color: red;
        font-weight: bold;
    }

    .error {
        color: red;
        font-weight: bold;
    }
</style>

<div class="container">
    <div class="des-container">

        @using (Html.BeginForm("Desencriptar", "Cesar", FormMethod.Post))
        {
            <div class="campo">
                <label>Frase encriptada</label>
                @Html.DropDownList("FraseEncriptada", (List<SelectListItem>)ViewBag.Frases)
            </div>

            <div class="campo">
                @Html.LabelFor(m => m.Desplazamiento)
                @Html.TextBoxFor(m => m.Desplazamiento, new { type = "number" })
            </div>

            <button type="submit" class="btn-custom">Desencriptar</button>
            @Html.ActionLink("Menú", "Menu", "Cesar", null, new { @class = "btn-custom" })
        }

        @if (ViewBag.FraseDesencriptada != null)
        {
            <div class="resultado">
                <p class="correcto">Frase desencriptada:</p>
                <p>@ViewBag.FraseDesencriptada</p>
                <p class="correcto">Frase Original</p>
                <p>@ViewBag.FraseOriginal</p>
            </div>
        }

        @if (ViewBag.Correcto != null)
        {
            <div class="correcto">@ViewBag.Correcto</div>
        }

        @if (ViewBag.Incorrecto != null)
        {
            <div class="incorrecto">@ViewBag.Incorrecto</div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

    </div>
</div>
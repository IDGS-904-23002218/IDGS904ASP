@model IDGS904ASP.Models.Palabra

@{
    ViewBag.Title = "Diccionario - Capturar";
}

<style>
    body {
        background-color: #1a1a2e;
    }

    .dic-container {
        background: linear-gradient(to bottom, #16213e, #0f3460);
        border: 3px solid #e0e0e0;
        border-radius: 10px;
        padding: 30px;
        margin-top: 20px;
        color: white;
        box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }

    .titulo-principal {
        text-align: center;
        margin-bottom: 25px;
    }

        .titulo-principal span {
            background: white;
            color: #0f3460;
            padding: 6px 30px;
            font-size: 26px;
            font-family: Georgia;
            font-style: italic;
            font-weight: bold;
            border-radius: 4px;
        }

    .panel-box {
        border: 2px solid rgba(255,255,255,0.4);
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        width: 400px;
        margin-left: auto;
        margin-right: auto;
    }

    .panel-titulo {
        font-size: 20px;
        font-style: italic;
        font-family: Georgia;
        margin-bottom: 15px;
        color: white;
    }

    .campo {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

        .campo label {
            width: 130px;
            font-size: 15px;
            color: white;
        }

        .campo input[type="text"] {
            width: 200px;
            padding: 5px;
            border-radius: 3px;
            border: none;
            color: black;
        }

    .acciones-box {
        text-align: center;
        margin-top: 15px;
    }

    .btn-custom {
        background: #f2f2f2;
        border: 1px solid #999;
        padding: 8px 25px;
        margin: 0 10px;
        border-radius: 4px;
        color: black;
        font-weight: bold;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-custom:hover {
            background: #ddd;
            color: black;
            text-decoration: none;
        }

    .mensaje {
        color: #90ee90;
        text-align: center;
        margin-top: 15px;
        font-weight: bold;
    }

    .error {
        color: yellow;
        text-align: center;
        margin-top: 15px;
        font-weight: bold;
    }
</style>

<div class="container">
    <div class="dic-container">

        <div class="titulo-principal">
            <span>Diccionario — Capturar</span>
        </div>

        @using (Html.BeginForm("Capturar", "Diccionario", FormMethod.Post))
        {
            <div class="panel-box">
                <div class="panel-titulo">Nueva Palabra</div>

                <div class="campo">
                    @Html.LabelFor(m => m.Espanol)
                    @Html.TextBoxFor(m => m.Espanol)
                </div>

                <div class="campo">
                    @Html.LabelFor(m => m.Ingles)
                    @Html.TextBoxFor(m => m.Ingles)
                </div>
            </div>

            <div class="acciones-box">
                <input type="submit" value="Guardar" class="btn-custom" />
                @Html.ActionLink("Buscar", "Buscar", "Diccionario", null, new { @class = "btn-custom" })
                @Html.ActionLink("Salir", "Index", "Home", null, new { @class = "btn-custom" })
            </div>
        }

        @if (ViewBag.Mensaje != null)
        {
            <div class="mensaje">@ViewBag.Mensaje</div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

    </div>
</div>